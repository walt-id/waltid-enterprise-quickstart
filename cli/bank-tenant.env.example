# Copy to bank-tenant.env and adjust for your environment.
# Used by: npx tsx walt.ts --setup-bank-tenant

# Enterprise stack API host (same as main CLI)
BASE_URL=https://enterprise.test.waltid.cloud
ORGANIZATION=waltid

# Bank tenant ID (separate from default waltid-tenant01)
BANK_TENANT=bank-tenant

# Public base URL for issuer and verifier services
BANK_TENANT_BASE_URL=https://public-domain.com

# Base URL for SD-JWT VCT values (payment_account credential type)
VCT_BASE_URL=https://public-domain.com

# Keycloak OIDC for issuer auth provider
KEYCLOAK_AUTHORIZE_URL=https://keycloak.demo.walt.id/realms/mynewrealm/protocol/openid-connect/auth
KEYCLOAK_ACCESS_TOKEN_URL=https://keycloak.demo.walt.id/realms/mynewrealm/protocol/openid-connect/token
KEYCLOAK_CLIENT_ID=issuer_api
KEYCLOAK_CLIENT_SECRET=your-client-secret
KEYCLOAK_DEFAULT_SCOPES=openid,profile

# Admin credentials for authentication (falls back to walt.env if not set)
ADMIN_EMAIL=admin@walt.id
ADMIN_PASSWORD=admin123456

# attestation key file for issuer. If no attestation key is provided, the issuer will not require attestation.
WALLET_ATTESTER_KEY_FILE=attester-key.json
