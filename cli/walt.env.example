# Copy to walt.env and adjust for your environment.
# Loaded automatically by the CLI (before command-specific env files).

# Enterprise stack API host
BASE_URL=enterprise.localhost
PORT=7500
ORGANIZATION=waltid
TENANT=waltid-tenant01

# Optional: create host alias during --recreate / --init-system
# Maps this domain to the organization (see HOST_ALIAS_TARGET)
HOST_ALIAS_DOMAIN=

# Optional: host-alias service target (default: {ORGANIZATION}.host-alias)
# Example tenant-level target: waltid.tenant1.my-alias
HOST_ALIAS_TARGET=

# Admin credentials for authentication
# Default: admin@walt.id
ADMIN_EMAIL=admin@walt.id
# Default: admin123456
ADMIN_PASSWORD=admin123456

ATTESTER_KEY_FILE=attester-key.json