# Copy to gov-services.env and adjust for your environment.
# Used by: npx tsx walt.ts --setup-gov-services

# Enterprise stack API host (same as main CLI)
BASE_URL=enterprise.localhost
PORT=7500
ORGANIZATION=waltid

# Central government tenant ID
GOV_TENANT=gov-central

# Public base URL for issuer and verifier services
GOV_SERVICES_BASE_URL=https://gov.example.com

# Base URL for SD-JWT VCT values (defaults to GOV_SERVICES_BASE_URL)
GOV_VCT_BASE_URL=https://gov.example.com

# Optional global OpenID display metadata fallback for all government issuers.
# GOV_ISSUER_DISPLAY_NAME=Government Services Issuer
# GOV_ISSUER_DISPLAY_LOCALE=en-US
# GOV_ISSUER_DISPLAY_LOGO_URI=https://gov.example.com/logo.png
# GOV_ISSUER_DISPLAY_LOGO_ALT_TEXT=Government services issuer logo

# Per-issuer OpenID display metadata. These override the built-in distinct defaults.
GOV_HR_ISSUER_DISPLAY_NAME=Human Resources Credential Issuer
GOV_HR_ISSUER_DISPLAY_LOCALE=en-US
GOV_HR_ISSUER_DISPLAY_LOGO_URI=https://gov.example.com/logos/gov-hr-issuer.png
GOV_HR_ISSUER_DISPLAY_LOGO_ALT_TEXT=Human Resources issuer logo

GOV_IDENTITY_ISSUER_DISPLAY_NAME=Identity Services Issuer
GOV_IDENTITY_ISSUER_DISPLAY_LOCALE=en-US
GOV_IDENTITY_ISSUER_DISPLAY_LOGO_URI=https://gov.example.com/logos/gov-identity-issuer.png
GOV_IDENTITY_ISSUER_DISPLAY_LOGO_ALT_TEXT=Identity Services issuer logo

GOV_REVENUE_ISSUER_DISPLAY_NAME=Revenue Authority Issuer
GOV_REVENUE_ISSUER_DISPLAY_LOCALE=en-US
GOV_REVENUE_ISSUER_DISPLAY_LOGO_URI=https://gov.example.com/logos/gov-revenue-issuer.png
GOV_REVENUE_ISSUER_DISPLAY_LOGO_ALT_TEXT=Revenue Authority issuer logo

GOV_FINANCE_ISSUER_DISPLAY_NAME=Financial Services Issuer
GOV_FINANCE_ISSUER_DISPLAY_LOCALE=en-US
GOV_FINANCE_ISSUER_DISPLAY_LOGO_URI=https://gov.example.com/logos/gov-finance-issuer.png
GOV_FINANCE_ISSUER_DISPLAY_LOGO_ALT_TEXT=Financial Services issuer logo

# Central verifier OpenID client metadata.
GOV_CENTRAL_VERIFIER_CLIENT_NAME=Government Services Verifier
GOV_CENTRAL_VERIFIER_LOGO_URI=https://gov.example.com/logos/gov-central-verifier.png

# Untrusted demo issuer/verifier overrides.
GOV_UNTRUSTED_ISSUER_DISPLAY_NAME=Untrusted Department Issuer
GOV_UNTRUSTED_ISSUER_DISPLAY_LOGO_URI=https://gov.example.com/logos/gov-untrusted-issuer.png
GOV_UNTRUSTED_VERIFIER_CLIENT_NAME=Untrusted Department Verifier
GOV_UNTRUSTED_VERIFIER_LOGO_URI=https://gov.example.com/logos/gov-untrusted-verifier.png

# Department tenant IDs (each gets its own issuer)
GOV_DEPT_HR=dept-hr
GOV_DEPT_IDENTITY=dept-identity
GOV_DEPT_REVENUE=dept-revenue
GOV_DEPT_FINANCE=dept-finance


KEYCLOAK_AUTHORIZE_URL=https://keycloak.demo.walt.id/realms/mynewrealm/protocol/openid-connect/auth
KEYCLOAK_ACCESS_TOKEN_URL=https://keycloak.demo.walt.id/realms/mynewrealm/protocol/openid-connect/token
KEYCLOAK_CLIENT_ID=client
KEYCLOAK_CLIENT_SECRET=secret
KEYCLOAK_DEFAULT_SCOPES=openid,profile