# Copy to gov-services.env and adjust for your environment.
# Used by: npx tsx walt.ts --setup-gov-services

# Enterprise stack API host (same as main CLI)
BASE_URL=enterprise.localhost
PORT=7500
ORGANIZATION=waltid

# Central government tenant ID
GOV_TENANT=gov-central

# Public base URL for issuer and verifier services
GOV_SERVICES_BASE_URL=https://gov.example.com

# Base URL for SD-JWT VCT values (defaults to GOV_SERVICES_BASE_URL)
GOV_VCT_BASE_URL=https://gov.example.com

# Department tenant IDs (each gets its own issuer)
GOV_DEPT_HR=dept-hr
GOV_DEPT_IDENTITY=dept-identity
GOV_DEPT_REVENUE=dept-revenue
GOV_DEPT_FINANCE=dept-finance
