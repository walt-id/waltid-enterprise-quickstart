{
  "name": "walt-id-enterprise-cli",
  "version": "1.0.0",
  "description": "walt.id Enterprise Stack CLI Tool - Setup and run credential issuance/verification flows",
  "type": "module",
  "main": "walt.ts",
  "bin": {
    "walt": "./walt.ts"
  },
  "scripts": {
