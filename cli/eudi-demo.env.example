# EUDI Demo Configuration
# Copy this file to eudi-demo.env and customize as needed.

# =============================================================================
# WRP Registry Settings
# =============================================================================

# WRP Registry base URL
EUDI_REGISTRY_BASE_URL=https://registry.serviceproviders.eudiw.dev

# =============================================================================
# Tenant and Service Settings
# =============================================================================

# Tenant ID for the EUDI demo verifier
EUDI_TENANT=eudi-demo

# Verifier service name
EUDI_VERIFIER_NAME=eudi-verifier

# Public base URL for the verifier service (used in client metadata)
EUDI_SERVICE_BASE_URL=https://enterprise.walt.id

# =============================================================================
# Legal Entity Information (walt.id GmbH)
# =============================================================================

# Country code (ISO 3166-1 alpha-2)
EUDI_LEGAL_ENTITY_COUNTRY=AT

# Legal name of the organization
EUDI_LEGAL_ENTITY_NAME=walt.id GmbH

# Organization identifier (e.g., VAT number)
EUDI_LEGAL_ENTITY_IDENTIFIER=ATUID123456789

# Identifier type URI
EUDI_LEGAL_ENTITY_IDENTIFIER_TYPE=http://data.europa.eu/eudi/id/VAT-No

# Contact email
EUDI_LEGAL_ENTITY_EMAIL=office@walt.id

# Contact phone (international format)
EUDI_LEGAL_ENTITY_PHONE=+436648860100

# Postal address
EUDI_LEGAL_ENTITY_ADDRESS=Liechtensteinstrasse 111/115, 1090 Vienna, Austria

# Information URI (organization website)
EUDI_LEGAL_ENTITY_INFO_URI=https://walt.id

# =============================================================================
# Provider Settings
# =============================================================================

# Provider type: WALLET_PROVIDER or RELYING_PARTY_PROVIDER
EUDI_PROVIDER_TYPE=RELYING_PARTY_PROVIDER

# Policy URI (terms of service, practice statement)
EUDI_PROVIDER_POLICY_URI=https://walt.id/privacy-policy

# =============================================================================
# Wallet Relying Party Settings
# =============================================================================

# Trade name (displayed to users)
EUDI_WRP_TRADE_NAME=walt.id Identity Verification

# Service description
EUDI_WRP_DESCRIPTION=EUDI Wallet verification service powered by walt.id

# Support URI
EUDI_WRP_SUPPORT_URI=https://walt.id/contact

# Registry URI
EUDI_WRP_REGISTRY_URI=https://registry.serviceproviders.eudiw.dev

# Is Public Sector Body (true/false)
EUDI_WRP_IS_PSB=false

# Entitlements (comma-separated)
EUDI_WRP_ENTITLEMENTS=AGE_VERIFICATION,IDENTITY_VERIFICATION

# =============================================================================
# Intended Use Settings
# =============================================================================

# Intended use identifier
EUDI_INTENDED_USE_ID=USE-WALTID-001

# Purpose description
EUDI_INTENDED_USE_PURPOSE=Identity verification for walt.id enterprise services

# Privacy policy URI
EUDI_INTENDED_USE_PRIVACY_URI=https://walt.id/privacy-policy

# =============================================================================
# Credential Settings
# =============================================================================

# Credential format (jwt_vc, mso_mdoc, etc.)
EUDI_CREDENTIAL_FORMAT=jwt_vc

# Claims to request (comma-separated JSON paths)
EUDI_CREDENTIAL_CLAIMS=credentialSubject.name,credentialSubject.dateOfBirth

# Credential name
EUDI_CREDENTIAL_NAME=PID Credential

# Credential version
EUDI_CREDENTIAL_VERSION=1.0

# =============================================================================
# Supervisory Authority Settings (Austrian Data Protection Authority)
# =============================================================================

# Authority name
EUDI_SUPERVISORY_AUTHORITY_NAME=DSB

# Authority country
EUDI_SUPERVISORY_AUTHORITY_COUNTRY=AT

# Authority email
EUDI_SUPERVISORY_AUTHORITY_EMAIL=dsb@dsb.gv.at

# Authority phone
EUDI_SUPERVISORY_AUTHORITY_PHONE=+43152152

# Authority contact form URI
EUDI_SUPERVISORY_AUTHORITY_FORM_URI=https://www.dsb.gv.at/kontakt

# =============================================================================
# Legal Basis Settings
# =============================================================================

# Legal basis (comma-separated)
EUDI_LAW_LEGAL_BASIS=consent,contract

# Legislative identifier
EUDI_LAW_LEGISLATIVE_ID=GDPR-ART-6

# =============================================================================
# Certificate Settings
# =============================================================================

# Password for the PKCS#12 certificate (change this!)
EUDI_CERTIFICATE_PASSWORD=WaltIdEudi2024!
